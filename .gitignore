```gitignore
# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2022
.vs/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates
*.sln.ide
*.VC.db
*.VC.VC.opendb
*.opendb

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Rider / JetBrains
.idea/
*.sln.iml

# .NET / ASP.NET Core
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets
artifacts/
TestResults/
CoverageReport/
coverage/
coverage.xml
coverage.cobertura.xml
*.coverage
*.coveragexml
*.trx

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
!**/packages/repositories.config
*.nuspec

# Entity Framework / SQLite local files
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ASP.NET Core local settings
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
secrets.json

# User secrets should not be committed
secrets/
*.secret.json

# Environment variables
.env
.env.*
!.env.example

# Docker
docker-compose.override.yml
docker-compose.*.override.yml
.docker/
docker-data/
docker-volumes/

# Kubernetes / local deployment files
*.kubeconfig
kubeconfig
.kube/
local-values.yaml
values.local.yaml

# Certificates / keys
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer
*.csr
*.jks
*.keystore

# Publish output
publish/
published/
wwwroot/dist/
wwwroot/build/

# Node / frontend dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
.next/
.nuxt/
.cache/
.parcel-cache/

# TypeScript / frontend generated files
*.tsbuildinfo

# Logs
*.log
*.tlog

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*
*.orig

# OS generated files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Windows Recycle Bin
$RECYCLE.BIN/

# IIS / local web server
_ReSharper*/
*.DotSettings.user
IISExpress/
.vs/config/applicationhost.config

# Azure / deployment local artifacts
.azure/
*.PublishSettings
*.pubxml.user

# AWS local config - avoid committing credentials
.aws/
samconfig.toml

# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl

# SonarQube / analysis
.sonarqube/
.scannerwork/

# ReSharper
_ReSharper.Caches/
*.DotSettings.user

# StyleCop / analyzers generated cache
StyleCop.Cache

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# Generated files
Generated/
generated/
*.generated.cs

# Backup folders
Backup/
backup/
```
