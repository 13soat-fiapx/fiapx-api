{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppInfo": {
    "Name": "FIAP X - Media Processing API",
    "Description": "API REST para upload, status e download de resultados de processamento de vídeos.",
    "RoutePrefix": ""
  },
  "Authentication": {
    "Enabled": false,
    "Authority": "",
    "Audience": ""
  },
  "LocalUser": {
    "Id": "auth0|local-user",
    "Name": "Local User",
    "Email": "local.user@example.com"
  },
  "AwsCredentials": {
    "Region": "us-east-1",
    "UseLocalstack": true,
    "LocalstackUrl": "http://localhost:4566",
    "AccessKey": "test",
    "SecretAccessKey": "test",
    "SessionToken": "test"
  },
  "StorageOptions": {
    "BucketName": "fiapx-media",
    "Region": "us-east-1",
    "UploadUrlExpirationMinutes": 15,
    "DownloadUrlExpirationMinutes": 5,
    "PublicServiceUrl": "http://localhost:4566"
  },
  "MessagingOptions": {
    "DisableConsumers": true,
    "QueueNames": {
      "VideoProcessingRequested": "video-processing-requested"
    }
  },
  "TableNames": {
    "ProcessingJobs": "fiapx-processing-jobs"
  }
}
